# Same Supabase project as ABOS — copy these from ABOS's Vercel env vars
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Comma-separated list of emails allowed to log in as the store/owner
# (sees ALL conversations, not just their own)
VITE_OWNER_EMAILS=owner@example.com

# --- Server-side only (used by /api/groq-reply.js — do NOT prefix with VITE_) ---
# Same Groq key ABOS already uses.
GROQ_API_KEY=your-groq-key
# Supabase → Settings → API → "service_role" key (NOT the anon key).
# Needed to insert AI replies bypassing RLS. Keep this secret — set it
# only in Vercel's environment variables, never commit it or expose it
# to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
